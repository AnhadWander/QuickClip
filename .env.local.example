# ─── QUICKCLIP ENVIRONMENT VARIABLES ──────────────────────────────────────────

# LLM Selection (gemini or openai)
LLM_PROVIDER="gemini"

# Mock Mode (set to "true" to run the UI without making any real API calls)
NEXT_PUBLIC_USE_MOCK="false"

# ─── LLM Credentials ────────────────────────────────────────────────────────
# Required if LLM_PROVIDER="gemini"
GEMINI_API_KEY="your_google_gen_ai_key_here"
GEMINI_MODEL="gemini-3.1-flash-lite-preview""

# Required if LLM_PROVIDER="openai"
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o-mini"

# ─── Firebase Client Side (Public) ──────────────────────────────────────────
# Find these in Firebase Console -> Project Settings -> General -> Web App
NEXT_PUBLIC_FIREBASE_API_KEY="Add Key Here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="quickclip-a5d17.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="quickclip-a5d17"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="quickclip-a5d17.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="590711397266"
NEXT_PUBLIC_FIREBASE_APP_ID="1:590711397266:web:ac35408576cc81f973ff4b"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-PKCTSXLPV3"

