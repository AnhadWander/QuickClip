rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly lock down the entire database by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write to user history only if the user is authenticated 
    // and the userId perfectly matches the Auth UID.
    match /users/{userId}/history/{historyId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
